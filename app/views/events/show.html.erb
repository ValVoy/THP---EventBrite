<div class="container mt-5 mb-5">
  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card shadow-lg border-0 rounded-4 overflow-hidden" style="background: #161b22; border: 1px solid #30363d !important;">
        <div class="p-4 border-bottom border-secondary" style="background: linear-gradient(145deg, #0d1117 0%, #161b22 100%);">
          <h1 class="fw-bold text-white mb-2"><%= @event.title %></h1>
          <div class="d-flex align-items-center gap-3 text-secondary small">
            <span>📍 <%= @event.location %></span>
            <span>•</span>
            <span>📅 <%= @event.start_date.strftime("%d %B %Y à %H:%M") %></span>
          </div>
        </div>
        <div class="card-body p-4 text-secondary">
          <h5 class="text-white fw-bold mb-3">À propos de cet événement</h5>
          <p class="fs-5" style="line-height: 1.6;"><%= @event.description %></p>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card shadow-lg border-0 rounded-4 p-4 sticky-top" style="background: #161b22; border: 1px solid #30363d !important; top: 2rem;">
        <h2 class="text-success fw-bold mb-4"><%= @event.price %> €</h2>
        <div class="mb-4 small">
          <div class="d-flex justify-content-between mb-2">
            <span class="text-secondary">Durée</span>
            <span class="text-white fw-bold"><%= @event.duration %> min</span>
          </div>
          <div class="d-flex justify-content-between">
            <span class="text-secondary">Inscrits</span>
            <span class="text-white fw-bold"><%= @event.attendances.count %> personnes</span>
          </div>
        </div>
        <div class="d-grid gap-2">
          <% if user_signed_in? %>
            <% if current_user == @event.admin %>
              <%= link_to "Modifier", edit_event_path(@event), class: "btn btn-outline-info rounded-pill" %>
            <% elsif @event.users.include?(current_user) %>
              <button class="btn btn-secondary rounded-pill py-3 fw-bold" disabled>✅ Inscrit</button>
            <% else %>
              <%= button_to "S'inscrire", event_attendances_path(@event), method: :post, class: "btn btn-success rounded-pill py-3 fw-bold" %>
            <% end %>
          <% else %>
            <%= link_to "Se connecter pour s'inscrire", new_user_session_path, class: "btn btn-primary rounded-pill py-3 fw-bold" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>