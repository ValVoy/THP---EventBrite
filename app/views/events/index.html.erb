<div class="container mt-5">
  <div class="p-5 mb-4 bg-body-tertiary rounded-3 text-center shadow-sm">
    <div class="container-fluid py-5">
      <h1 class="display-5 fw-bold">Bienvenue sur Eventbrite-Like</h1>
      <p class="col-md-8 mx-auto fs-4">Trouvez les meilleurs événements dans votre ville, ou proposez le vôtre à la communauté !</p>
      <%= link_to "Créer un événement", new_event_path, class: "btn btn-primary btn-lg mt-3" %>
    </div>
  </div>

  <h2 class="mb-4">Prochains événements</h2>
  <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
    <% @events.each do |event| %>
      <div class="col">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <h5 class="card-title fw-bold"><%= event.title %></h5>
            <h6 class="card-subtitle mb-3 text-muted">
              📅 <%= event.start_date.strftime("%d/%m/%Y à %H:%M") %>
            </h6>
            <p class="card-text"><%= truncate(event.description, length: 120) %></p>
          </div>
          <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
            <span class="badge bg-success fs-6"><%= event.price %> €</span>
            <%= link_to "Voir plus", event_path(event.id), class: "btn btn-sm btn-outline-primary" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>