<!DOCTYPE html>
<html data-bs-theme="dark" class="h-100">
  <head>
    <title>EventbriteLike</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <%# On charge le JS ici avec reload pour fixer Turbo %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" data-turbo-track="reload" defer></script>
    
    <%= yield :head %>
  </head>

  <body style="background-color: #0d1117; margin: 0; padding: 0;">
    <%= render "layouts/navbar" %>
    
    <%# Conteneur des messages flash sans marge parasite %>
    <div class="container mt-2">
      <% flash.each do |key, message| %>
        <div class="alert alert-<%= key == 'notice' ? 'success' : 'danger' %> alert-dismissible fade show border-0" role="alert">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>
    </div>

    <main>
      <%= yield %>
    </main>
  </body>
</html>