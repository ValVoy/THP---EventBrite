<div class="container mt-5 mb-5">
  <div class="row g-4 justify-content-center">
    <div class="col-lg-4">
      <div class="card border-0 rounded-4 shadow-lg h-100" style="background: #161b22; border: 1px solid #30363d !important;">
        <div class="card-body text-center p-5">
          <div class="rounded-circle bg-primary d-inline-flex align-items-center justify-content-center text-white fw-bold mb-3 shadow" style="width: 100px; height: 100px; font-size: 2.5rem;">
            <%= @user.email[0].upcase %>
          </div>
          <h3 class="fw-bold text-white mb-1"><%= @user.first_name %> <%= @user.last_name %></h3>
          <p class="text-secondary small mb-4"><%= @user.email %></p>
          <hr class="border-secondary mb-4">
          <div class="text-start">
            <h6 class="text-primary fw-bold small text-uppercase mb-2">Ma Description</h6>
            <p class="text-secondary small mb-4"><%= @user.description.presence || "Aucune description renseignée." %></p>
            <%= link_to "Modifier mes infos", edit_user_registration_path, class: "btn btn-outline-secondary w-100 rounded-pill btn-sm" %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-7">
      <h3 class="fw-bold text-white mb-4">Événements que j'organise</h3>
      <% if @events.any? %>
        <div class="list-group gap-3">
          <% @events.each do |event| %>
            <%= link_to event_path(event), class: "list-group-item list-group-item-action rounded-4 p-4 d-flex justify-content-between align-items-center bg-dark text-white border-secondary profile-card" do %>
              <div>
                <h5 class="mb-1 fw-bold"><%= event.title %></h5>
                <small class="text-secondary">📅 <%= event.start_date.strftime("%d/%m/%Y") %></small>
              </div>
              <span class="badge bg-primary rounded-pill px-3 py-2"><%= event.price %> €</span>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="p-5 text-center rounded-4 border border-secondary border-dashed" style="background: #0d1117;">
          <p class="text-secondary mb-3">Vous n'avez pas encore créé d'événement.</p>
          <%= link_to "Lancer un événement", new_event_path, class: "btn btn-success rounded-pill fw-bold" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<style>
  .profile-card { background: #161b22 !important; border: 1px solid #30363d !important; transition: transform 0.2s; }
  .profile-card:hover { transform: scale(1.02); border-color: #58a6ff !important; }
</style>